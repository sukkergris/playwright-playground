{
  "name": "C# Playwright playground - Debian",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/xyz",
  "remoteUser": "container-user",
  "postCreateCommand": "bash .devcontainer/post-container-creation.sh",
  "mounts": [
    "source=claude-${localWorkspaceFolderBasename},target=/home/container-user/.claude,type=volume",
    "source=codex-${localWorkspaceFolderBasename},target=/home/container-user/.codex,type=volume",
    "source=gemini-${localWorkspaceFolderBasename},target=/home/container-user/.gemini,type=volume",
    "source=vscode-secrets-${localWorkspaceFolderBasename},target=/home/container-user/.vscode-server/data/Machine,type=volume",
    "source=config-${localWorkspaceFolderBasename},target=/home/container-user/.config,type=volume"
  ],
  "containerEnv": {
      "OLLAMA_HOST": "http://host.docker.internal:11434"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Continue.continue",
        "Anthropic.claude-code",
        "google.geminicodeassist",
        "usernamehw.errorlens",
        "humao.rest-client",
        "timonwong.shellcheck",
        "mads-hartmann.bash-ide-vscode",
        "rogalmic.bash-debug",
        "openai.chatgpt",
        "ms-vscode.powershell",
        "ms-dotnettools.csdevkit",
        "saoudrizwan.claude-dev"
      ]
    }
  }
}
