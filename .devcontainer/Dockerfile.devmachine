FROM mcr.microsoft.com/dotnet/sdk:10.0

# 1. Installer Linux dependencies til Chromium
RUN apt-get update && apt-get install -y \
    libnss3 \
    libnspr4 \
    libgbm1 \
    # Her bruger vi wildcard eller det specifikke nye navn til .NET 10/Ubuntu 24.04
    libasound2t64 || libasound2 \
    libpangocairo-1.0-0 \
    libx11-6 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    && rm -rf /var/lib/apt/lists/*